{
    "name": "@towers/shared",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./contracts": {
            "types": "./dist/contracts/index.d.ts",
            "default": "./dist/contracts/index.js"
        },
        "./env/api": {
            "types": "./dist/env/api.d.ts",
            "default": "./dist/env/api.js"
        },
        "./env/web": {
            "types": "./dist/env/web.d.ts",
            "default": "./dist/env/web.js"
        },
        "./hexgrid": {
            "types": "./dist/hexgrid/index.d.ts",
            "default": "./dist/hexgrid/index.js"
        }
    },
    "scripts": {
        "dev": "tsc-watch -p tsconfig.json --onSuccess \"echo 'Shared package rebuilt.'\"",
        "build": "tsc -p tsconfig.json && echo 'Shared package build complete.'"
    },
    "dependencies": {
        "typescript": "^5.9.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "tsc-watch": "^7.2.0"
    }
}
