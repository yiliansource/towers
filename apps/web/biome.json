{
    "$schema": "https://biomejs.dev/schemas/latest/schema.json",
    "extends": "//",
    "files": {
        "includes": ["src/**", "app/**", "components/**", "features/**", "*.ts", "*.tsx"]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "noRestrictedImports": {
                    "level": "error",
                    "options": {
                        "patterns": [
                            {
                                "group": ["@/features/*/**"],
                                "message": "Import from the feature root only."
                            }
                        ]
                    }
                }
            }
        }
    }
}
