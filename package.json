{
    "name": "towers",
    "private": true,
    "packageManager": "yarn@4.9.2",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"yarn dev:shared\" \"yarn dev:api\" \"yarn dev:web\" -n \"shared,api,web\" -c \"red,blue,green\"",
        "dev:shared": "yarn workspace @towers/shared dev",
        "dev:web": "yarn workspace @towers/web dev",
        "dev:api": "yarn workspace @towers/api dev",
        "build": "yarn workspaces foreach -Apvi --topological run build",
        "lint": "yarn workspaces foreach -Apvi run lint",
        "typecheck": "yarn workspaces foreach -Apvi run typecheck",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "concurrently": "^9.2.1",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "zod": "^4.3.6"
    }
}
