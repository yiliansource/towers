{
    "name": "towers",
    "private": true,
    "packageManager": "yarn@4.13.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"yarn dev:shared\" \"yarn dev:api\" \"yarn dev:web\" -n \"shared,api,web\" -c \"red,blue,green\"",
        "dev:shared": "yarn workspace @towers/shared dev",
        "dev:web": "yarn workspace @towers/web dev",
        "dev:api": "yarn workspace @towers/api dev",
        "build": "yarn build:shared && concurrently \"yarn build:api\" \"yarn build:web\" -n \"api,web\" -c \"blue,green\"",
        "build:shared": "yarn workspace @towers/shared build",
        "build:web": "yarn workspace @towers/web build",
        "build:api": "yarn workspace @towers/api build",
        "lint": "biome lint .",
        "format": "biome format . --write",
        "check": "biome check .",
        "check:write": "biome check . --write"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "concurrently": "^9.2.1",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "zod": "^4.3.6"
    }
}
